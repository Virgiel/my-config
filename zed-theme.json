{
  "$schema": "https://zed.dev/schema/themes/v0.2.0.json",
  "name": "Virgiel Theme",
  "author": "Virgiel",
  "themes": [
    {
      "name": "Virgiel Material",
      "appearance": "dark",
      "style": {
        "background": "#131414",
        "background.appearance": "opaque",
        "surface.background": "#131414",
        "panel.background": "#131414",
        "title_bar.background": "#131414",
        "status_bar.background": "#131414",
        "text": "#e2cca9",
        "text.muted": "#a89984",
        "text.placeholder": "#928374",
        "text.disabled": "#7c6f64",
        "text.accent": "#e78a4e",
        "editor.background": "#202020",
        "editor.gutter.background": "#202020",
        "editor.subheader.background": "#131414",
        "editor.active_line.background": "#32302f8c",
        "editor.highlighted_line.background": "#20202085",
        "editor.line_number": "#7c6f64",
        "editor.active_line_number": "#e2cca9",
        "editor.wrap_guide": "#32302f",
        "editor.active_wrap_guide": "#32302f",
        "editor.indent_guide": "#32302fa6",
        "editor.indent_guide_active": "#32302f",
        "editor.caret": "#ea6962",
        "editor.selection.background": "#32302fd1",
        "editor.active_selection.background": "#32302ff5",
        "editor.selection.border": "#00000000",
        "editor.document_highlight.read_background": "#32302fd9",
        "editor.document_highlight.write_background": "#32302fff",
        "editor.find_all_background": "#5a4728b8",
        "editor.find_match_background": "#e78a4e52",
        "editor.find_match_border": "#e78a4e",
        "editor.active_find_match.background": "#e78a4e8a",
        "editor.active_find_match.border": "#d8a657",
        "hint": "#928374",
        "hint.background": "#9283741a",
        "info": "#89b482",
        "info.background": "#89b4821a",
        "warning": "#d8a657",
        "warning.background": "#d8a6571a",
        "error": "#ea6962",
        "error.background": "#ea69621a",
        "created": "#a9b665",
        "modified": "#7daea3",
        "deleted": "#ea6962",
        "renamed": "#d3869b",
        "conflict": "#e78a4e",
        "ignored": "#7c6f64",
        "predictive": "#928374",
        "scrollbar.thumb.background": "#46403d80",
        "scrollbar.thumb.hover_background": "#46403d",
        "scrollbar.thumb.border": "#46403d8c",
        "scrollbar.track.background": "#00000000",
        "scrollbar.track.border": "#00000000",
        "editor.autocomplete.background": "#202020",
        "editor.autocomplete.border": "#32302f",
        "editor.autocomplete.selected_text": "#e2cca9",
        "editor.autocomplete.match_text": "#e78a4e",
        "editor.autocomplete.completion_documentation_primary_text": "#e2cca9",
        "editor.autocomplete.completion_documentation_secondary_text": "#a89984",
        "terminal.background": "#202020",
        "terminal.foreground": "#e2cca9",
        "terminal.ansi.black": "#32302f",
        "terminal.ansi.red": "#ea6962",
        "terminal.ansi.green": "#a9b665",
        "terminal.ansi.yellow": "#d8a657",
        "terminal.ansi.blue": "#7daea3",
        "terminal.ansi.magenta": "#d3869b",
        "terminal.ansi.cyan": "#89b482",
        "terminal.ansi.white": "#e2cca9",
        "link_text.hover": "#7daea3",
        "players": [
          {
            "cursor": "#e78a4e"
          }
        ],
        "syntax": {
          "comment": {
            "color": "#928374",
            "font_style": "italic"
          },
          "comment.doc": {
            "color": "#a89984",
            "font_style": "italic"
          },
          "punctuation": {
            "color": "#a89984"
          },
          "punctuation.bracket": {
            "color": "#928374"
          },
          "keyword": {
            "color": "#e78a4e",
            "font_style": "italic"
          },
          "operator": {
            "color": "#e78a4e"
          },
          "property": {
            "color": "#e2cca9"
          },
          "variable": {
            "color": "#e2cca9"
          },
          "function": {
            "color": "#89b482"
          },
          "type": {
            "color": "#d8a657"
          },
          "string": {
            "color": "#a9b665"
          },
          "string.escape": {
            "color": "#F00FFF"
          },
          "string.regex": {
            "color": "#F00FFF"
          },
          "string.special": {
            "color": "#a9b665",
            "font_style": "italic"
          },
          "string.special.symbol": {
            "color": "#F00FFF"
          },
          "attribute": {
            "color": "#d3869b"
          },
          "boolean": {
            "color": "#d3869b"
          },
          "variable.special": {
            "color": "#d3869b"
          },
          "hint": {
            "color": "#92837480"
          },
          "predictive": {
            "color": "#928374"
          },
          "embedded": {
            "color": "#F00FFF"
          },
          "emphasis": {
            "color": "#F00FFF"
          },
          "emphasis.strong": {
            "color": "#F00FFF"
          },
          "label": {
            "color": "#F00FFF"
          },
          "link_text": {
            "color": "#F00FFF"
          },
          "link_uri": {
            "color": "#F00FFF"
          },
          "number": {
            "color": "#d3869b"
          },
          "preproc": {
            "color": "#F00FFF"
          },
          "primary": {
            "color": "#F00FFF"
          }
        }
      }
    }
  ]
}